;npt
;https://manual.gromacs.org/documentation/2023-current/user-guide/mdp-options.html

define                  = -DPOSRES_XXXX


integrator              = md
dt                      = 0.002     ; 2 fs
nsteps                  = 500000    ; 2 fs * 500000 = 1 ns, 2 fs * 5000000 = 10 ns, 2 fs * 50000000 = 100 ns


constraint-algorithm    = LINCS
constraints             = h-bonds


cutoff-scheme           = Verlet
pbc                     = xyz


vdwtype                 = Cut-off
rvdw                    = 1.0
coulombtype             = PME
rcoulomb                = 1.0


tcoupl                  = nose-hoover
tc-grps                 = System
tau-t                   = 2.0
ref-t                   = 300


pcoupl                  = Parrinello-Rahman
pcoupltype              = isotropic
tau-p                   = 5.0
ref-p                   = 1.0
compressibility         = 4.5e-5
refcoord-scaling        = all


continuation            = yes
gen-vel                 = no




nstenergy               = 5000
nstlog                  = 5000
nstxout-compressed      = 5000
